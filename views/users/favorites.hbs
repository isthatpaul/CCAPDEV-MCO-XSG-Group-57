<main class="main">
    <div class="container">
        <div style="margin-bottom: 24px;">
            <h1>{{user.name}}'s Favorite Places</h1>
            <p style="color: #666; margin-top: 8px;">{{ favorites.length }} {{ pluralize favorites.length 'favorite' 'favorites' }}</p>
        </div>

        {{#if favorites.length}}
        <div class="card-grid">
            {{#each favorites}}
            {{> est-card}}
            {{/each}}
        </div>
        {{else}}
        <div class="card">
            <p style="color: #999; padding: 16px; text-align: center;">
                {{#if isOwnFavorites}}
                <strong>You haven't favorited any places yet!</strong><br>
                Start favoriting your favorite establishments.
                {{else}}
                <strong>No favorites yet</strong><br>
                This user hasn't favorited any places.
                {{/if}}
            </p>
        </div>
        {{/if}}
    </div>
</main>
