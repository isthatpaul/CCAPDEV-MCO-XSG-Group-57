<main class="main">
    <div class="container">
        <div style="margin-bottom: 24px;">
            <h1>{{user.name}}'s Favorite Places</h1>
            <p style="color: #666; margin-top: 8px;">{{favorites.length}} favorite{{#unless (eq favorites.length 1)}}s{{/unless}}</p>
        </div>

        {{#if favorites.length}}
        <div class="card-grid">
            {{#each favorites}}
            <a href="/establishments/{{ this._id }}" class="est-card">
                <div class="est-card-img">
                    <img src="/images/{{ this.image }}" alt="{{ this.name }}" style="width:100%; height:100%; object-fit:cover;">
                </div>
                <div class="est-card-body">
                    <h3>{{ this.name }}</h3>
                    <div class="est-card-rating">
                        <span class="stars">{{ stars this.rating }}</span>
                        <span class="rating-num">{{ this.rating }}</span>
                    </div>
                    <p>{{ this.description }}</p>
                </div>
            </a>
            {{/each}}
        </div>
        {{else}}
        <div class="card">
            <p style="color: #999; padding: 16px; text-align: center;">
                {{#if isOwnFavorites}}
                <strong>You haven't favorited any places yet!</strong><br>
                Start favoriting your favorite establishments.
                {{else}}
                <strong>No favorites yet</strong><br>
                This user hasn't favorited any places.
                {{/if}}
            </p>
        </div>
        {{/if}}
    </div>
</main>
