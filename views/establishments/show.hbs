<div class="establishment-det-holder">
    <img src="/images/{{ establishment.image }}" alt="{{ establishment.name }}" style="width: 100%; height: 300px; object-fit: cover;">
</div>

<!-- Detail Section -->
<section class="detail-header">
    <div class="container">
        <div id="details">
            <h2 class="establishment-title">{{ establishment.name }}</h2>
            
            <!-- Business Status Badge -->
            {{#if businessStatus}}
            {{#if (eq businessStatus.status "open")}}
            <div style="margin: 12px 0 16px 0; padding: 10px 14px; background: #4CAF50; color: white; border-radius: 4px; font-weight: 600; display: inline-block;">🟢 {{ businessStatus.message }}</div>
            {{else if (eq businessStatus.status "closing")}}
            <div style="margin: 12px 0 16px 0; padding: 10px 14px; background: #FF9800; color: white; border-radius: 4px; font-weight: 600; display: inline-block;">⏰ {{ businessStatus.message }}</div>
            {{else}}
            <div style="margin: 12px 0 16px 0; padding: 10px 14px; background: #f44336; color: white; border-radius: 4px; font-weight: 600; display: inline-block;">🔴 {{ businessStatus.message }}</div>
            {{/if}}
            {{/if}}

            <!-- Rating Breakdown -->
            <div style="margin: 20px 0; padding: 16px; background: #f9f9f9; border-radius: 8px;">
                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
                    <span style="font-size: 28px; font-weight: bold;">{{ establishment.rating }}</span>
                    <div>
                        <div style="font-size: 20px;">{{ stars establishment.rating }}</div>
                        <small style="color: #666;">{{ ratingBreakdown.total }} reviews</small>
                    </div>
                </div>
                {{#if ratingBreakdown.total}}
                <div style="font-size: 12px;">
                    <div style="display: flex; align-items: center; gap: 8px; margin: 8px 0;">
                        <span style="width: 30px;">5★</span>
                        <div style="background: #e0e0e0; width: 120px; height: 8px; border-radius: 4px; overflow: hidden;">
                            <div style="background: #FFB800; height: 100%; width: {{ratingPercentage ratingBreakdown.five ratingBreakdown.total}}%;"></div>
                        </div>
                        <span style="width: 30px; text-align: right;">{{ ratingBreakdown.five }}</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 8px; margin: 8px 0;">
                        <span style="width: 30px;">4★</span>
                        <div style="background: #e0e0e0; width: 120px; height: 8px; border-radius: 4px; overflow: hidden;">
                            <div style="background: #FFB800; height: 100%; width: {{ratingPercentage ratingBreakdown.four ratingBreakdown.total}}%;"></div>
                        </div>
                        <span style="width: 30px; text-align: right;">{{ ratingBreakdown.four }}</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 8px; margin: 8px 0;">
                        <span style="width: 30px;">3★</span>
                        <div style="background: #e0e0e0; width: 120px; height: 8px; border-radius: 4px; overflow: hidden;">
                            <div style="background: #FFB800; height: 100%; width: {{ratingPercentage ratingBreakdown.three ratingBreakdown.total}}%;"></div>
                        </div>
                        <span style="width: 30px; text-align: right;">{{ ratingBreakdown.three }}</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 8px; margin: 8px 0;">
                        <span style="width: 30px;">2★</span>
                        <div style="background: #e0e0e0; width: 120px; height: 8px; border-radius: 4px; overflow: hidden;">
                            <div style="background: #FFB800; height: 100%; width: {{ratingPercentage ratingBreakdown.two ratingBreakdown.total}}%;"></div>
                        </div>
                        <span style="width: 30px; text-align: right;">{{ ratingBreakdown.two }}</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 8px; margin: 8px 0;">
                        <span style="width: 30px;">1★</span>
                        <div style="background: #e0e0e0; width: 120px; height: 8px; border-radius: 4px; overflow: hidden;">
                            <div style="background: #FFB800; height: 100%; width: {{ratingPercentage ratingBreakdown.one ratingBreakdown.total}}%;"></div>
                        </div>
                        <span style="width: 30px; text-align: right;">{{ ratingBreakdown.one }}</span>
                    </div>
                </div>
                {{/if}}
            </div>

            <div class="main-content">
                <div class="main-left card">
                    <p><strong>Overall Rating:</strong> {{ stars establishment.rating }} {{ establishment.rating }}</p>
                    {{#if establishment.category}}<p><strong>Category:</strong> {{ establishment.category }}</p>{{/if}}
                    <p><strong>Location:</strong> {{#if establishment.location}}{{ establishment.location }}{{else}}<em>Not provided</em>{{/if}}</p>
                    <p><strong>Contact:</strong> {{#if establishment.contact}}{{ establishment.contact }}{{else}}<em>Not provided</em>{{/if}}</p>
                    {{#if establishment.phone}}<p><strong>Phone:</strong> <a href="tel:{{ establishment.phone }}" style="color: #007bff;">{{ formatPhone establishment.phone }}</a></p>{{/if}}
                    <p><strong>Hours:</strong> {{#if establishment.hours}}{{ establishment.hours }}{{else}}<em>Not provided</em>{{/if}}</p>
                    {{#if establishment.link}}<p><strong>Links:</strong> <a href="{{ establishment.link }}" target="_blank" rel="noopener noreferrer" style="color: #007bff;">Facebook ↗</a></p>{{/if}}
                </div>

                <div class="main-right card">
                    <h3>Description</h3>
                    <p id="estDescription">{{#if establishment.description}}{{ establishment.description }}{{else}}<em>No description provided</em>{{/if}}</p>
                </div>

                {{#if canEdit}}
                <button id="edit-button">Edit</button>

                <div class="card" id="edit-card" style="display:none;">
                    <h3>Edit Establishment</h3>
                    <form id="editEstablishmentForm" action="/establishments/{{ establishment._id }}/edit" method="POST" enctype="multipart/form-data">
                        <div>
                            <label>Establishment Name</label>
                            <input type="text" name="name" value="{{ establishment.name }}" required>
                        </div>
                        <div>
                            <label>Category</label>
                            <input type="text" name="category" value="{{ establishment.category }}" placeholder="e.g., Cafe, Italian Restaurant, Fast Food">
                        </div>
                        <div>
                            <label>Location</label>
                            <input type="text" id="editLocation" name="location" value="{{ establishment.location }}">
                        </div>
                        <div>
                            <label>Contact Email</label>
                            <input type="text" id="editContact" name="contact" value="{{ establishment.contact }}">
                        </div>
                        <div>
                            <label>Phone Number</label>
                            <input type="tel" name="phone" value="{{ establishment.phone }}" placeholder="e.g., (02) 123-4567">
                        </div>
                        <div>
                            <label>Hours</label>
                            <input type="text" id="editHours" name="hours" value="{{ establishment.hours }}" placeholder="e.g., 7:00 AM - 9:00 PM">
                        </div>
                        <div>
                            <label>Facebook Link</label>
                            <input type="url" id="editLink" name="link" value="{{ establishment.link }}" placeholder="https://facebook.com/...">
                        </div>
                        <div>
                            <label>Image</label>
                            <input type="file" name="image" accept="image/*">
                            {{#if establishment.image}}<small style="display: block; margin-top: 4px; color: #666;">Current image: {{ establishment.image }}</small>{{/if}}
                        </div>
                        <div>
                            <label>Description</label>
                            <textarea id="editDescription" name="description" rows="4">{{ establishment.description }}</textarea>
                        </div>
                        <div style="margin-top:10px">
                            <button type="submit">Save Changes</button>
                            <button type="button" id="cancelEditBtn">Cancel</button>
                        </div>
                    </form>
                </div>
                {{/if}}
            </div>
        </div>

        {{#if isLoggedIn}}
        <div class="detail-actions">
            <button id="writeReviewButton">Write a Review</button>
            <form action="/establishments/{{ establishment._id }}/favorites/toggle" method="POST" style="display:inline;">
                <button type="submit" class="btn-favorite {{#if isFavorited}}favorited{{/if}}" style="background: {{#if isFavorited}}#FF6B6B{{else}}#f0f0f0{{/if}}; color: {{#if isFavorited}}white{{else}}#333{{/if}};">
                    {{#if isFavorited}}★ Favorited{{else}}☆ Add to Favorites{{/if}}
                </button>
            </form>
        </div>
        {{/if}}
    </div>
</section>

<!-- Review Form Overlay -->
{{#if isLoggedIn}}
<div id="reviewOverlayForm" class="overlay" style="display:none;">
    <div class="popup">
        <h3>Write Review</h3>
        <form id="reviewForm" action="/reviews" method="POST">
            <input type="hidden" name="establishmentId" value="{{ establishment._id }}">
            <div>
                <label for="reviewTitle">Title</label>
                <input type="text" id="reviewTitle" name="title" placeholder="Give your review a title" required>
            </div>
            <div>
                <label for="reviewTextBody">Your Review</label>
                <textarea id="reviewTextBody" name="comment" rows="5" placeholder="Write your review..."></textarea>
            </div>
            <div>
                <label>Rating</label>
                <div class="star-rating">
                    <label for="star1" title="1 star">1★</label>
                    <input type="radio" id="star1" name="rating" value="1">
                    <label for="star2" title="2 stars">2★</label>
                    <input type="radio" id="star2" name="rating" value="2">
                    <label for="star3" title="3 stars">3★</label>
                    <input type="radio" id="star3" name="rating" value="3">
                    <label for="star4" title="4 stars">4★</label>
                    <input type="radio" id="star4" name="rating" value="4">
                    <label for="star5" title="5 stars">5★</label>
                    <input type="radio" id="star5" name="rating" value="5" required>
                </div>
            </div>
            <button type="submit">Post Review</button>
            <button type="button" class="cancel">Cancel</button>
        </form>
    </div>
</div>

<!-- Edit Review Form Overlay -->
<div id="editReviewOverlay" class="overlay" style="display:none;">
    <div class="popup">
        <h3>Edit Review</h3>
        <form id="editReviewForm" method="POST">
            <div>
                <label for="editTitle">Title</label>
                <input type="text" id="editTitle" name="title" required>
            </div>
            <div>
                <label for="editComment">Your Review</label>
                <textarea id="editComment" name="comment" rows="5" required></textarea>
            </div>
            <div>
                <label>Rating</label>
                <select id="editRating" name="rating" required>
                    <option value="1">1★</option>
                    <option value="2">2★</option>
                    <option value="3">3★</option>
                    <option value="4">4★</option>
                    <option value="5">5★</option>
                </select>
            </div>
            <button type="submit">Update Review</button>
            <button type="button" class="cancel" onclick="closeEditOverlay()">Cancel</button>
        </form>
    </div>
</div>
{{/if}}

<!-- Reviews Section -->
<section class="review-section">
    <div class="container">
        <div class="review-list">
            <div class="review-list-header">
                <h3>Reviews</h3>
                <span>{{ reviews.length }} review{{#unless (eq reviews.length 1)}}s{{/unless}}</span>
            </div>

            <!-- Review Filters & Sorting -->
            <div style="margin-bottom: 16px; padding: 12px; background: #f9f9f9; border-radius: 4px;">
                <form method="GET" style="display: flex; gap: 12px; flex-wrap: wrap;">
                    <div>
                        <label for="filter-rating" style="font-size: 14px;">Filter by Rating:</label>
                        <select id="filter-rating" name="rating" onchange="this.form.submit()" style="padding: 6px; border-radius: 4px; border: 1px solid #ddd;">
                            <option value="">All Ratings</option>
                            <option value="5" {{#if (eq ratingFilter 5)}}selected{{/if}}>⭐⭐⭐⭐⭐ 5 Star</option>
                            <option value="4" {{#if (eq ratingFilter 4)}}selected{{/if}}>⭐⭐⭐⭐ 4 Star</option>
                            <option value="3" {{#if (eq ratingFilter 3)}}selected{{/if}}>⭐⭐⭐ 3 Star</option>
                            <option value="2" {{#if (eq ratingFilter 2)}}selected{{/if}}>⭐⭐ 2 Star</option>
                            <option value="1" {{#if (eq ratingFilter 1)}}selected{{/if}}>⭐ 1 Star</option>
                        </select>
                    </div>
                    <div>
                        <label for="sort-by" style="font-size: 14px;">Sort by:</label>
                        <select id="sort-by" name="sort" onchange="this.form.submit()" style="padding: 6px; border-radius: 4px; border: 1px solid #ddd;">
                            <option value="newest" {{#if (eq sortBy "newest")}}selected{{/if}}>Newest</option>
                            <option value="highest-rated" {{#if (eq sortBy "highest-rated")}}selected{{/if}}>Highest Rated</option>
                            <option value="lowest-rated" {{#if (eq sortBy "lowest-rated")}}selected{{/if}}>Lowest Rated</option>
                            <option value="most-helpful" {{#if (eq sortBy "most-helpful")}}selected{{/if}}>Most Helpful</option>
                        </select>
                    </div>
                    {{#if ratingFilter}}
                    <div>
                        <a href="/establishments/{{ ../establishment._id }}" style="padding: 6px 12px; background: #f0f0f0; border-radius: 4px; text-decoration: none; font-size: 14px;">Clear Filters</a>
                    </div>
                    {{/if}}
                </form>
            </div>

            {{#each reviews}}
            <div class="review-list-item">
                <div class="review-list-item-header">
                    <img src="{{ imageUrl this.userId.image }}" alt="{{ this.userId.name }}" class="review-list-avatar" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;">
                    <div>
                        <h4><a href="/users/{{ this.userId._id }}"><strong>{{ this.userId.name }}</strong></a></h4>
                        <span>{{ formatDate this.createdAt }}</span>
                    </div>
                </div>
                <div class="review-list-stars">{{ stars this.rating }}</div>
                <h4>{{ this.title }}</h4>
                <p>{{ this.comment }}</p>

                {{#if this.images}}
                <div style="display: flex; gap: 8px; margin: 12px 0; flex-wrap: wrap;">
                    {{#each this.images}}
                    <img src="{{ this }}" alt="Review image" style="max-width: 100px; max-height: 100px; border-radius: 4px; object-fit: cover; cursor: pointer;" onclick="openImageOverlay('{{ this }}')">
                    {{/each}}
                </div>
                {{/if}}

                <div class="review-actions" style="display: flex; gap: 12px; margin-top: 8px;">
                    {{#if (eq ../currentUserId this.userId._id)}}
                    <button type="button" class="btn-vote" style="background: #10b92f; color: white;" 
                        onclick="openEditReview('{{this._id}}', '{{this.title}}', '{{this.comment}}', '{{this.rating}}')">
                        Edit
                    </button>
                    <form action="/reviews/{{ this._id }}/delete" method="POST" style="display:inline;">
                        <button type="submit" class="btn-vote" style="background: #ff6b6b; color: white;">Delete</button>
                    </form>
                    {{/if}}
                    
                    {{#if ../isLoggedIn}}
                    <form action="/reviews/{{ this._id }}/helpful" method="POST" style="display:inline;">
                        <button type="submit" class="btn-vote review-vote-btn" data-review-id="{{ this._id }}" data-vote-type="helpful" style="background: #4CAF50; color: white;">
                            👍 Helpful ({{ this.helpfulVotes.length }})
                        </button>
                    </form>
                    <form action="/reviews/{{ this._id }}/unhelpful" method="POST" style="display:inline;">
                        <button type="submit" class="btn-vote review-vote-btn" data-review-id="{{ this._id }}" data-vote-type="unhelpful" style="background: #f44336; color: white;">
                            👎 Unhelpful ({{ this.unhelpfulVotes.length }})
                        </button>
                    </form>
                    {{/if}}
                    
                    {{!-- Owner Reply --}}
                    {{#if this.ownerReply.comment}}
                    <div class="owner-reply" style="margin-left: 40px; margin-top: 10px; padding: 10px; background: #f0f7ff; border-left: 4px solid #007bff; border-radius: 4px;">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                            <div style="flex-grow: 1;">
                                <strong>Response from Owner:</strong>
                                <p style="margin: 5px 0;">{{this.ownerReply.comment}}</p>
                                <small style="color: #666;">{{formatDate this.ownerReply.createdAt}}</small>
                            </div>

                            {{!-- Show Delete Button only if user is authorized (canEdit) --}}
                            {{#if ../canEdit}}
                                <button type="button" 
                                        style="background: #ff6b6b; color: white; border: none; padding: 4px 10px; border-radius: 4px; cursor: pointer; font-size: 11px; font-weight: bold; margin-left: 10px;"
                                        onclick="openDeleteReply('{{this._id}}')">
                                    Delete
                                </button>
                            {{/if}}
                        </div>
                    </div>
                    {{/if}}

                    {{#if ../canEdit}} 
                        {{#unless this.ownerReply.comment}}
                        <button onclick="document.getElementById('reply-form-{{this._id}}').style.display='block'" class="btn-vote">Reply</button>
                        
                        <div id="reply-form-{{this._id}}" style="display:none; margin-top: 10px;">
                            <form action="/reviews/{{this._id}}/reply" method="POST">
                                <textarea name="comment" placeholder="Write your response..." required style="width:100%; padding:8px;"></textarea>
                                <button type="submit" class="btn-vote" style="background:#007bff; color:white;">Post Reply</button>
                                <button type="button" onclick="this.parentElement.parentElement.style.display='none'">Cancel</button>
                            </form>
                        </div>
                        {{/unless}}
                    {{/if}}
                </div>
            </div>
            {{else}}
            <p style="color: #999; padding: 16px;">No reviews yet. Be the first to review!</p>
            {{/each}}
        </div>
    </div>
</section>

{{!-- Delete Reply Overlay --}}
<div id="deleteReplyOverlay" class="overlay" style="display:none;">
    <div class="popup" style="max-width: 400px; text-align: center;">
        <h3>Delete Reply?</h3>
        <p>Are you sure you want to remove your response? This action cannot be undone.</p>
        <form id="deleteReplyForm" method="POST">
            <div style="display: flex; gap: 10px; justify-content: center; margin-top: 20px;">
                <button type="submit" style="background: #ff6b6b; color: white;">Yes, Delete</button>
                <button type="button" class="cancel" onclick="closeDeleteOverlay()">Cancel</button>
            </div>
        </form>
    </div>
</div>

<!-- Recommendations Section -->
{{#if recommendations.length}}
<section style="background: #f9f9f9; padding: 40px 0; border-top: 1px solid #eee; margin-top: 40px;">
    <div class="container">
        <h2 style="margin-top: 0; margin-bottom: 24px;">People Also Liked 👍</h2>
        <div class="card-grid">
            {{#each recommendations}}
            <a href="/establishments/{{ this._id }}" class="est-card">
                <div class="est-card-img">
                    <img src="/images/{{ this.image }}" alt="{{ this.name }}" style="width:100%; height:100%; object-fit:cover;">
                </div>
                <div class="est-card-body">
                    <h3>{{ this.name }}</h3>
                    <div class="est-card-rating">
                        <span class="stars">{{ stars this.rating }}</span>
                        <span class="rating-num">{{ this.rating }}</span>
                    </div>
                    <p>{{ this.description }}</p>
                </div>
            </a>
            {{/each}}
        </div>
    </div>
</section>
{{/if}}

<script>
    // Edit establishment toggle
    var editBtn = document.getElementById('edit-button');
    var editCard = document.getElementById('edit-card');
    var cancelEditBtn = document.getElementById('cancelEditBtn');

    if (editBtn) {
        editBtn.addEventListener('click', function() {
            editCard.style.display = 'block';
        });
    }
    if (cancelEditBtn) {
        cancelEditBtn.addEventListener('click', function() {
            editCard.style.display = 'none';
        });
    }

    // Review overlay toggle
    var writeBtn = document.getElementById('writeReviewButton');
    var reviewOverlay = document.getElementById('reviewOverlayForm');

    if (writeBtn && reviewOverlay) {
        var cancelReview = reviewOverlay.querySelector('.cancel');
        writeBtn.addEventListener('click', function() {
            reviewOverlay.style.display = 'flex';
        });
        cancelReview.addEventListener('click', function() {
            reviewOverlay.style.display = 'none';
        });
    }

    // Review Edit Form Overlay
    function openEditReview(id, title, comment, rating) {
        const overlay = document.getElementById('editReviewOverlay');
        const form = document.getElementById('editReviewForm');
        
        // Set form values
        form.action = `/reviews/${id}/edit`;
        document.getElementById('editTitle').value = title;
        document.getElementById('editComment').value = comment;
        document.getElementById('editRating').value = rating;
        
        overlay.style.display = 'flex';
    }

    function closeEditOverlay() {
        document.getElementById('editReviewOverlay').style.display = 'none';
    }

    function openDeleteReply(reviewId) {
        const overlay = document.getElementById('deleteReplyOverlay');
        const form = document.getElementById('deleteReplyForm');
        
        form.action = `/reviews/${reviewId}/reply/delete`;
        
        overlay.style.display = 'flex';
    }

    function closeDeleteOverlay() {
        document.getElementById('deleteReplyOverlay').style.display = 'none';
    }

    // Image overlay for review images
    function openImageOverlay(imageSrc) {
        const overlay = document.createElement('div');
        overlay.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.8);display:flex;align-items:center;justify-content:center;z-index:1000;';
        overlay.onclick = function() { overlay.remove(); };
        
        const img = document.createElement('img');
        img.src = imageSrc;
        img.style.cssText = 'max-width:90%;max-height:90%;border-radius:8px;';
        
        overlay.appendChild(img);
        document.body.appendChild(overlay);
    }

    // Handle vote button state management
    const userHasVoted = {{{ json userHasVoted }}};
    document.querySelectorAll('.review-vote-btn').forEach(btn => {
        const reviewId = btn.getAttribute('data-review-id');
        const voteType = btn.getAttribute('data-vote-type');
        
        if (userHasVoted[reviewId]) {
            if (voteType === 'helpful' && userHasVoted[reviewId].helpful) {
                btn.style.background = '#2e7d32';
                btn.disabled = true;
            } else if (voteType === 'unhelpful' && userHasVoted[reviewId].unhelpful) {
                btn.style.background = '#c62828';
                btn.disabled = true;
            }
        }
    });

</script>