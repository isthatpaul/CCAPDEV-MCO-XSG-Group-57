<div class="establishment-det-holder">
    <img src="{{ imageUrl establishment.image }}" alt="{{ establishment.name }}" style="width: 100%; height: 300px; object-fit: cover;">
</div>

<!-- Detail Section -->
<section class="detail-header">
    <div class="container">
        <div id="details">
            <!-- Header with Title and Rating Breakdown -->
            <div style="display: flex; gap: 32px; align-items: flex-start; margin-bottom: 20px;">
                <div style="flex: 1;">
                    <h2 class="establishment-title">{{ establishment.name }}</h2>
                    
                    <!-- Business Status Badge -->
                    {{#if businessStatus}}
                    <div style="margin: 12px 0 16px 0; padding: 10px 14px; background: {{statusColor businessStatus.status}}; color: white; border-radius: 4px; font-weight: 600; display: inline-block;">{{statusEmoji businessStatus.status}} {{ businessStatus.message }}</div>
                    {{/if}}

                    <!-- Action Buttons -->
                    {{#if isLoggedIn}}
                    <div class="detail-actions">
                        {{#if canEdit}}
                        <button id="edit-button">✏️ Edit Establishment</button>
                        {{/if}}
                        <button id="writeReviewButton">📝 Write a Review</button>
                        <form action="/establishments/{{ establishment._id }}/favorites/toggle" method="POST" style="display:inline;">
                            <button type="submit" class="btn-favorite {{#if isFavorited}}favorited{{/if}}">
                                {{#if isFavorited}}★ Favorited{{else}}☆ Favorite{{/if}}
                            </button>
                        </form>
                    </div>
                    {{/if}}
                </div>

                <!-- Rating Breakdown -->
                <div style="flex: 0 0 300px; padding: 16px; background: #f9f9f9; border-radius: 8px; border: 1px solid #e0e0e0;">
                    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
                        <span style="font-size: 28px; font-weight: bold;">{{ establishment.rating }}</span>
                        <div>
                            <div style="font-size: 20px;">{{ stars establishment.rating }}</div>
                            <small style="color: #666;">{{ ratingBreakdown.total }} reviews</small>
                        </div>
                    </div>
                    {{#if ratingBreakdown.total}}
                    <div style="font-size: 12px;">
                        <div style="display: flex; align-items: center; gap: 8px; margin: 8px 0;">
                            <span style="width: 30px;">5★</span>
                            <div style="background: #e0e0e0; width: 100px; height: 8px; border-radius: 4px; overflow: hidden;">
                                <div style="background: #FFB800; height: 100%; width: {{ratingPercentage ratingBreakdown.five ratingBreakdown.total}}%;"></div>
                            </div>
                            <span style="width: 25px; text-align: right;">{{ ratingBreakdown.five }}</span>
                        </div>
                        <div style="display: flex; align-items: center; gap: 8px; margin: 8px 0;">
                            <span style="width: 30px;">4★</span>
                            <div style="background: #e0e0e0; width: 100px; height: 8px; border-radius: 4px; overflow: hidden;">
                                <div style="background: #FFB800; height: 100%; width: {{ratingPercentage ratingBreakdown.four ratingBreakdown.total}}%;"></div>
                            </div>
                            <span style="width: 25px; text-align: right;">{{ ratingBreakdown.four }}</span>
                        </div>
                        <div style="display: flex; align-items: center; gap: 8px; margin: 8px 0;">
                            <span style="width: 30px;">3★</span>
                            <div style="background: #e0e0e0; width: 100px; height: 8px; border-radius: 4px; overflow: hidden;">
                                <div style="background: #FFB800; height: 100%; width: {{ratingPercentage ratingBreakdown.three ratingBreakdown.total}}%;"></div>
                            </div>
                            <span style="width: 25px; text-align: right;">{{ ratingBreakdown.three }}</span>
                        </div>
                        <div style="display: flex; align-items: center; gap: 8px; margin: 8px 0;">
                            <span style="width: 30px;">2★</span>
                            <div style="background: #e0e0e0; width: 100px; height: 8px; border-radius: 4px; overflow: hidden;">
                                <div style="background: #FFB800; height: 100%; width: {{ratingPercentage ratingBreakdown.two ratingBreakdown.total}}%;"></div>
                            </div>
                            <span style="width: 25px; text-align: right;">{{ ratingBreakdown.two }}</span>
                        </div>
                        <div style="display: flex; align-items: center; gap: 8px; margin: 8px 0;">
                            <span style="width: 30px;">1★</span>
                            <div style="background: #e0e0e0; width: 100px; height: 8px; border-radius: 4px; overflow: hidden;">
                                <div style="background: #FFB800; height: 100%; width: {{ratingPercentage ratingBreakdown.one ratingBreakdown.total}}%;"></div>
                            </div>
                            <span style="width: 25px; text-align: right;">{{ ratingBreakdown.one }}</span>
                        </div>
                    </div>
                    {{/if}}
                </div>
            </div>

            <div class="main-content">
                <div class="main-left card">
                    {{#if establishment.category}}<p><strong>Category:</strong> {{ establishment.category }}</p>{{/if}}
                    <p><strong>Location:</strong> {{#if establishment.location}}{{ establishment.location }}{{else}}<em>Not provided</em>{{/if}}</p>
                    {{#if establishment.contact}}<p><strong>Contact Email:</strong> <a href="mailto:{{ establishment.contact }}" style="color: #007bff;">{{ establishment.contact }}</a></p>{{/if}}
                    {{#if establishment.phone}}<p><strong>Phone:</strong> <a href="tel:{{ establishment.phone }}" style="color: #007bff;">{{ formatPhone establishment.phone }}</a></p>{{/if}}
                    {{#if establishment.hours}}
                    <div style="margin-top: 12px;">
                        <strong>Operating Hours:</strong>
                        <table class="hours-table">
                            <tbody>
                                <tr>
                                    <td>Sunday</td>
                                    <td>{{ formatDayHours (getHoursByDay establishment.hours 0) }}</td>
                                </tr>
                                <tr>
                                    <td>Monday</td>
                                    <td>{{ formatDayHours (getHoursByDay establishment.hours 1) }}</td>
                                </tr>
                                <tr>
                                    <td>Tuesday</td>
                                    <td>{{ formatDayHours (getHoursByDay establishment.hours 2) }}</td>
                                </tr>
                                <tr>
                                    <td>Wednesday</td>
                                    <td>{{ formatDayHours (getHoursByDay establishment.hours 3) }}</td>
                                </tr>
                                <tr>
                                    <td>Thursday</td>
                                    <td>{{ formatDayHours (getHoursByDay establishment.hours 4) }}</td>
                                </tr>
                                <tr>
                                    <td>Friday</td>
                                    <td>{{ formatDayHours (getHoursByDay establishment.hours 5) }}</td>
                                </tr>
                                <tr>
                                    <td>Saturday</td>
                                    <td>{{ formatDayHours (getHoursByDay establishment.hours 6) }}</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    {{else}}
                    <p><strong>Hours:</strong> <em>Not provided</em></p>
                    {{/if}}
                    {{#if establishment.link}}<p><strong>Links:</strong> <a href="{{ establishment.link }}" target="_blank" rel="noopener noreferrer" style="color: #007bff;">Facebook ↗</a></p>{{/if}}
                </div>

                <div class="main-right card">
                    <h3>Description</h3>
                    <p id="estDescription">{{#if establishment.description}}{{ establishment.description }}{{else}}<em>No description provided</em>{{/if}}</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Edit Establishment Overlay -->
{{#if canEdit}}
<div id="editEstablishmentOverlay" class="overlay" style="display:none;">
    <div class="popup" style="max-width: 600px; max-height: 90vh; overflow-y: auto;">
        <h3>Edit Establishment</h3>
        <form id="editEstablishmentForm" action="/establishments/{{ establishment._id }}/edit" method="POST" enctype="multipart/form-data">
            {{> error-flash}}
            <div>
                <label for="editName">Establishment Name</label>
                <input type="text" id="editName" name="name" value="{{ establishment.name }}" required>
            </div>
            <div>
                <label for="editCategory">Category</label>
                <input type="text" id="editCategory" name="category" value="{{ establishment.category }}" placeholder="e.g., Cafe, Italian Restaurant, Fast Food">
            </div>
            <div>
                <label for="editLocationField">Location</label>
                <input type="text" id="editLocationField" name="location" value="{{ establishment.location }}" required>
            </div>
            <div>
                <label for="editContact">Contact Email</label>
                <input type="email" id="editContact" name="contact" value="{{ establishment.contact }}">
            </div>
            <div>
                <label for="editPhone">Phone Number</label>
                <input type="tel" id="editPhone" name="phone" value="{{ establishment.phone }}" placeholder="e.g., 09123456789 or +639123456789" pattern="^[0-9\-\+]{5,15}$" title="Enter a valid phone number with 5 to 15 digits.">
            </div>
            <div class="hours-container">
                <label><strong>Operating Hours</strong></label>
                {{#each establishment.hours}}
                <div class="day-hours">
                    <label>
                        {{#if (eq this.dayOfWeek 0)}}Sunday
                        {{else if (eq this.dayOfWeek 1)}}Monday
                        {{else if (eq this.dayOfWeek 2)}}Tuesday
                        {{else if (eq this.dayOfWeek 3)}}Wednesday
                        {{else if (eq this.dayOfWeek 4)}}Thursday
                        {{else if (eq this.dayOfWeek 5)}}Friday
                        {{else}}Saturday{{/if}}
                    </label>
                    <div class="time-inputs">
                        <input type="checkbox" name="hours[{{ this.dayOfWeek }}][isClosed]" {{#if this.isClosed}}checked{{/if}}> Closed
                    </div>
                    <div class="time-row">
                        <input type="time" name="hours[{{ this.dayOfWeek }}][openTime]" value="{{ this.openTime }}">
                        <span>to</span>
                        <input type="time" name="hours[{{ this.dayOfWeek }}][closeTime]" value="{{ this.closeTime }}">
                    </div>
                </div>
                {{/each}}
            </div>
            <div>
                <label for="editLink">Facebook Link</label>
                <input type="url" id="editLink" name="link" value="{{ establishment.link }}" placeholder="https://facebook.com/...">
            </div>
            <div>
                <label for="editImageUpload">Image</label>
                <input type="file" id="editImageUpload" name="image" accept="image/*">
                {{#if establishment.image}}<small style="display: block; margin-top: 4px; color: #666;">Current image will be kept if no new file is chosen.</small>{{/if}}
            </div>
            <div>
                <label for="editDescription">Description</label>
                <textarea id="editDescription" name="description" rows="4">{{ establishment.description }}</textarea>
            </div>
            <div style="margin-top:10px">
                <button type="submit">Save Changes</button>
                <button type="button" id="cancelEditBtn">Cancel</button>
            </div>
        </form>
    </div>
</div>
{{/if}}

<!-- Review Form Overlay -->
{{#if isLoggedIn}}
<div id="reviewOverlayForm" class="overlay" style="display:none;">
    <div class="popup">
        <h3>Write Review</h3>
        <form id="reviewForm" action="/reviews" method="POST">
            <input type="hidden" name="establishmentId" value="{{ establishment._id }}">
            <div>
                <label for="reviewTitle">Title</label>
                <input type="text" id="reviewTitle" name="title" placeholder="Give your review a title" required>
            </div>
            <div>
                <label for="reviewTextBody">Your Review</label>
                <textarea id="reviewTextBody" name="comment" rows="5" placeholder="Write your review..." required></textarea>
            </div>
            <div>
                <label>Rating</label>
                <div class="drag-rating-slider">
                    <div class="stars-container">
                        <span class="star" data-value="1">★</span>
                        <span class="star" data-value="2">★</span>
                        <span class="star" data-value="3">★</span>
                        <span class="star" data-value="4">★</span>
                        <span class="star" data-value="5">★</span>
                    </div>
                    <input type="hidden" name="rating" id="reviewRating" required>
                    <div class="rating-display">
                        <span id="ratingValue">0</span>/5 stars
                    </div>
                </div>
            </div>
            <button type="submit">Post Review</button>
            <button type="button" class="cancel">Cancel</button>
        </form>
    </div>
</div>

<!-- Edit Review Form Overlay -->
<div id="editReviewOverlay" class="overlay" style="display:none;">
    <div class="popup">
        <h3>Edit Review</h3>
        <form id="editReviewForm" method="POST">
            <div>
                <label for="editTitle">Title</label>
                <input type="text" id="editTitle" name="title" required>
            </div>
            <div>
                <label for="editComment">Your Review</label>
                <textarea id="editComment" name="comment" rows="5" required></textarea>
            </div>
            <div>
                <label>Rating</label>
                <div class="drag-rating-slider">
                    <div class="stars-container">
                        <span class="star" data-value="1">★</span>
                        <span class="star" data-value="2">★</span>
                        <span class="star" data-value="3">★</span>
                        <span class="star" data-value="4">★</span>
                        <span class="star" data-value="5">★</span>
                    </div>
                    <input type="hidden" name="rating" id="editRating" required>
                    <div class="rating-display">
                        <span id="editRatingValue">0</span>/5 stars
                    </div>
                </div>
            </div>
            <button type="submit">Update Review</button>
            <button type="button" class="cancel" onclick="closeEditOverlay()">Cancel</button>
        </form>
    </div>
</div>
{{/if}}

<!-- Reviews Section -->
<section class="review-section">
    <div class="container">
        <div class="review-list">
            <div class="review-list-header">
                <h3>Reviews</h3>
                <span>{{ reviews.length }} {{ pluralize reviews.length 'review' 'reviews' }}</span>
            </div>

            <!-- Review Filters & Sorting -->
            <div class="review-filter-bar">
                <form method="GET" class="review-filter-form">
                    <div class="review-filter-group">
                        <label for="filter-rating">Filter by Rating:</label>
                        <select id="filter-rating" name="rating" onchange="this.form.submit()">
                            <option value="">All Ratings</option>
                            <option value="5" {{#if (eq ratingFilter 5)}}selected{{/if}}>⭐⭐⭐⭐⭐ 5 Star</option>
                            <option value="4" {{#if (eq ratingFilter 4)}}selected{{/if}}>⭐⭐⭐⭐ 4 Star</option>
                            <option value="3" {{#if (eq ratingFilter 3)}}selected{{/if}}>⭐⭐⭐ 3 Star</option>
                            <option value="2" {{#if (eq ratingFilter 2)}}selected{{/if}}>⭐⭐ 2 Star</option>
                            <option value="1" {{#if (eq ratingFilter 1)}}selected{{/if}}>⭐ 1 Star</option>
                        </select>
                    </div>
                    <div class="review-filter-group">
                        <label for="sort-by">Sort by:</label>
                        <select id="sort-by" name="sort" onchange="this.form.submit()">
                            <option value="newest" {{#if (eq sortBy "newest")}}selected{{/if}}>Newest</option>
                            <option value="highest-rated" {{#if (eq sortBy "highest-rated")}}selected{{/if}}>Highest Rated</option>
                            <option value="lowest-rated" {{#if (eq sortBy "lowest-rated")}}selected{{/if}}>Lowest Rated</option>
                            <option value="most-helpful" {{#if (eq sortBy "most-helpful")}}selected{{/if}}>Most Helpful</option>
                        </select>
                    </div>
                    {{#if ratingFilter}}
                    <div class="review-filter-group">
                        <a href="/establishments/{{ ../establishment._id }}" class="btn-clear-filter">Clear Filters</a>
                    </div>
                    {{/if}}
                </form>
            </div>

            {{#each reviews}}
            <div class="review-list-item">
                <div class="review-list-item-header">
                    <img src="{{ imageUrl this.userId.image }}" alt="{{ this.userId.name }}" class="review-list-avatar" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;">
                    <div>
                        <h4><a href="/users/{{ this.userId._id }}"><strong>{{ this.userId.name }}</strong></a></h4>
                        <span>{{ formatDate this.createdAt }}</span>
                    </div>
                </div>
                <div class="review-list-stars">{{ stars this.rating }}</div>
                <h4>{{ this.title }}</h4>
                <p>{{ this.comment }}</p>

                {{#if this.images}}
                <div style="display: flex; gap: 8px; margin: 12px 0; flex-wrap: wrap;">
                    {{#each this.images}}
                    <img src="{{ this }}" alt="Review image" style="max-width: 100px; max-height: 100px; border-radius: 4px; object-fit: cover; cursor: pointer;" onclick="openImageOverlay('{{ this }}')">
                    {{/each}}
                </div>
                {{/if}}

                <div class="review-actions">
                    {{#if (eq ../currentUserId this.userId._id)}}
                    <button type="button" class="btn-vote btn-edit-review" 
                        data-review-id="{{this._id}}"
                        data-review-title="{{this.title}}"
                        data-review-comment="{{this.comment}}"
                        data-review-rating="{{this.rating}}"
                        onclick="openEditReview(this)">
                        Edit
                    </button>
                    <form action="/reviews/{{ this._id }}/delete" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this review? This cannot be undone.')">
                        <button type="submit" class="btn-vote btn-delete-review">Delete</button>
                    </form>
                    {{/if}}
                    
                    {{#if ../isLoggedIn}}
                    <form action="/reviews/{{ this._id }}/helpful" method="POST" style="display:inline;">
                        <button type="submit" class="btn-vote btn-helpful review-vote-btn" data-review-id="{{ this._id }}" data-vote-type="helpful">
                            👍 Helpful ({{ this.helpfulVotes.length }})
                        </button>
                    </form>
                    <form action="/reviews/{{ this._id }}/unhelpful" method="POST" style="display:inline;">
                        <button type="submit" class="btn-vote btn-unhelpful review-vote-btn" data-review-id="{{ this._id }}" data-vote-type="unhelpful">
                            👎 Unhelpful ({{ this.unhelpfulVotes.length }})
                        </button>
                    </form>
                    {{/if}}
                    
                    {{!-- Owner Reply --}}
                    {{#if this.ownerReply.comment}}
                    <div class="owner-reply" style="margin-left: 40px; margin-top: 10px; padding: 10px; background: #f0f7ff; border-left: 4px solid #007bff; border-radius: 4px;">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                            <div style="flex-grow: 1;">
                                <strong>Response from Owner:</strong>
                                <p style="margin: 5px 0;">{{this.ownerReply.comment}}</p>
                                <small style="color: #666;">{{formatDate this.ownerReply.createdAt}}</small>
                            </div>

                            {{!-- Show Delete Button only if user is authorized (canEdit) --}}
                            {{#if ../canEdit}}
                                <button type="button" 
                                        style="background: #ff6b6b; color: white; border: none; padding: 4px 10px; border-radius: 4px; cursor: pointer; font-size: 11px; font-weight: bold; margin-left: 10px;"
                                        onclick="openDeleteReply('{{this._id}}')">
                                    Delete
                                </button>
                            {{/if}}
                        </div>
                    </div>
                    {{/if}}

                    {{#if ../canEdit}} 
                        {{#unless this.ownerReply.comment}}
                        <button onclick="document.getElementById('reply-form-{{this._id}}').style.display='block'" class="btn-vote">Reply</button>
                        
                        <div id="reply-form-{{this._id}}" style="display:none; margin-top: 10px;">
                            <form action="/reviews/{{this._id}}/reply" method="POST">
                                <label for="reply-comment-{{this._id}}" class="sr-only">Write your owner response</label>
                                <textarea id="reply-comment-{{this._id}}" name="comment" placeholder="Write your response..." required style="width:100%; padding:8px;"></textarea>
                                <button type="submit" class="btn-vote btn-reply-post">Post Reply</button>
                                <button type="button" onclick="this.parentElement.parentElement.style.display='none'">Cancel</button>
                            </form>
                        </div>
                        {{/unless}}
                    {{/if}}
                </div>
            </div>
            {{else}}
            <p style="color: #999; padding: 16px;">No reviews yet. Be the first to review!</p>
            {{/each}}
        </div>
    </div>
</section>

{{!-- Delete Reply Overlay --}}
<div id="deleteReplyOverlay" class="overlay" style="display:none;">
    <div class="popup" style="max-width: 400px; text-align: center;">
        <h3>Delete Reply?</h3>
        <p>Are you sure you want to remove your response? This action cannot be undone.</p>
        <form id="deleteReplyForm" method="POST">
            <div style="display: flex; gap: 10px; justify-content: center; margin-top: 20px;">
                <button type="submit" style="background: #ff6b6b; color: white;">Yes, Delete</button>
                <button type="button" class="cancel" onclick="closeDeleteOverlay()">Cancel</button>
            </div>
        </form>
    </div>
</div>

<!-- Recommendations Section -->
{{#if recommendations.length}}
<section class="recommendations-section">
    <div class="container">
        <h2 class="recommendations-heading">People Also Liked 👍</h2>
        <div class="card-grid">
            {{#each recommendations}}
            {{> est-card}}
            {{/each}}
        </div>
    </div>
</section>
{{/if}}

<script>
    // Star Rating Picker
    function setupStarRating(containerId, inputId, displayId) {
        const container = document.querySelector(`#${containerId} .stars-container`);
        const input = document.getElementById(inputId);
        const display = document.getElementById(displayId);
        if (!container) return;

        const stars = Array.from(container.querySelectorAll('.star'));

        function highlight(count) {
            stars.forEach((s, i) => s.classList.toggle('active', i < count));
        }

        function setRating(value) {
            input.value = value;
            if (display) display.textContent = value;
            highlight(value);
        }

        stars.forEach((star, i) => {
            star.addEventListener('mouseover', () => highlight(i + 1));
            star.addEventListener('click', () => setRating(i + 1));
            star.addEventListener('touchstart', (e) => {
                e.preventDefault();
                setRating(i + 1);
            }, { passive: false });
        });

        container.addEventListener('mouseleave', () => highlight(parseInt(input.value) || 0));
    }

    // Initialize write review rating
    setupStarRating('reviewOverlayForm', 'reviewRating', 'ratingValue');

    // Initialize edit review rating
    setupStarRating('editReviewOverlay', 'editRating', 'editRatingValue');

    // Edit establishment toggle
    var editBtn = document.getElementById('edit-button');
    var editOverlay = document.getElementById('editEstablishmentOverlay');
    var cancelEditBtn = document.getElementById('cancelEditBtn');
    var editEstForm = document.getElementById('editEstablishmentForm');

    if (editBtn && editOverlay) {
        editBtn.addEventListener('click', function() {
            editOverlay.style.display = 'flex';
        });
    }
    if (cancelEditBtn) {
        cancelEditBtn.addEventListener('click', function() {
            editOverlay.style.display = 'none';
        });
    }

    // Close overlay when clicking outside
    if (editOverlay) {
        editOverlay.addEventListener('click', function(e) {
            if (e.target === editOverlay) {
                editOverlay.style.display = 'none';
            }
        });
    }

    // Intercept edit establishment submit — close overlay + toast before reload
    if (editEstForm) {
        editEstForm.addEventListener('submit', function(e) {
            e.preventDefault();
            var formData = new FormData(this);
            var action = this.action;
            fetch(action, { method: 'POST', body: formData })
                .then(function(res) {
                    if (res.ok || res.redirected) {
                        editOverlay.style.display = 'none';
                        showToast('\u2713 Establishment updated!', 'success');
                        setTimeout(function() { location.reload(); }, 1200);
                    } else {
                        showToast('\u2717 Failed to save changes', 'error');
                    }
                })
                .catch(function() {
                    showToast('\u2717 Error saving changes', 'error');
                });
        });
    }

    // Review overlay toggle
    var writeBtn = document.getElementById('writeReviewButton');
    var reviewOverlay = document.getElementById('reviewOverlayForm');

    if (writeBtn && reviewOverlay) {
        var cancelReview = reviewOverlay.querySelector('.cancel');
        writeBtn.addEventListener('click', function() {
            reviewOverlay.style.display = 'flex';
        });
        cancelReview.addEventListener('click', function() {
            reviewOverlay.style.display = 'none';
        });
    }

    // Review Edit Form Overlay — uses data attributes to prevent XSS from inline onclick
    function openEditReview(btn) {
        var id = btn.getAttribute('data-review-id');
        var title = btn.getAttribute('data-review-title');
        var comment = btn.getAttribute('data-review-comment');
        var rating = parseInt(btn.getAttribute('data-review-rating'), 10);
        const overlay = document.getElementById('editReviewOverlay');
        const form = document.getElementById('editReviewForm');
        
        // Set form values
        form.action = `/reviews/${id}/edit`;
        document.getElementById('editTitle').value = title;
        document.getElementById('editComment').value = comment;
        
        // Set rating with drag slider
        const ratingInput = document.getElementById('editRating');
        const ratingDisplay = document.getElementById('editRatingValue');
        ratingInput.value = rating;
        ratingDisplay.textContent = rating;
        
        const stars = overlay.querySelectorAll('.star');
        stars.forEach((star, index) => {
            if (index + 1 <= rating) {
                star.classList.add('active');
            } else {
                star.classList.remove('active');
            }
        });
        
        overlay.style.display = 'flex';
    }

    function closeEditOverlay() {
        document.getElementById('editReviewOverlay').style.display = 'none';
    }

    function openDeleteReply(reviewId) {
        const overlay = document.getElementById('deleteReplyOverlay');
        const form = document.getElementById('deleteReplyForm');
        
        form.action = `/reviews/${reviewId}/reply/delete`;
        
        overlay.style.display = 'flex';
    }

    function closeDeleteOverlay() {
        document.getElementById('deleteReplyOverlay').style.display = 'none';
    }

    // Image overlay for review images
    function openImageOverlay(imageSrc) {
        const overlay = document.createElement('div');
        overlay.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.8);display:flex;align-items:center;justify-content:center;z-index:1000;';
        overlay.onclick = function() { overlay.remove(); };
        
        const img = document.createElement('img');
        img.src = imageSrc;
        img.style.cssText = 'max-width:90%;max-height:90%;border-radius:8px;';
        
        overlay.appendChild(img);
        document.body.appendChild(overlay);
    }

    // Handle vote button state management
    const userHasVoted = {{{ json userHasVoted }}};
    document.querySelectorAll('.review-vote-btn').forEach(btn => {
        const reviewId = btn.getAttribute('data-review-id');
        const voteType = btn.getAttribute('data-vote-type');
        
        if (userHasVoted[reviewId]) {
            if (voteType === 'helpful' && userHasVoted[reviewId].helpful) {
                btn.style.background = '#2e7d32';
                btn.disabled = true;
            } else if (voteType === 'unhelpful' && userHasVoted[reviewId].unhelpful) {
                btn.style.background = '#c62828';
                btn.disabled = true;
            }
        }
    });

</script>