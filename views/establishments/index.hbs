<!-- Search Section -->
<section class="search-section">
    <div class="container">
        <div style="display: flex; justify-content: space-between; align-items: center; gap: 16px; margin-bottom: 16px;">
            <h1 style="margin: 0;">Find Establishments</h1>
            {{#if (eq adminType "database_admin")}}
            <a href="/establishments/new" class="btn" style="display: inline-block; padding: 12px 20px; text-decoration: none;">+ Add New</a>
            {{/if}}
        </div>
        <form id="searchForm" class="search-form" action="/establishments" method="get">
            <input type="text" id="searchInput" name="q" placeholder="Search for restaurants, cuisines, or locations..." value="{{ query }}">
            <button type="submit">Search</button>
        </form>
        <a href="/establishments"><button type="button" id="resetSearchBtn" class="reset-btn">Show All</button></a>
    </div>
</section>

<!-- Filters Section -->
<section style="background: #f9f9f9; padding: 16px 0; border-bottom: 1px solid #eee;">
    <div class="container">
        <form method="GET" style="display: flex; gap: 16px; flex-wrap: wrap; align-items: center;">
            <input type="hidden" name="q" value="{{ query }}">
            
            <div>
                <label for="rating-filter" style="font-weight: 600; margin-right: 8px;">Minimum Rating:</label>
                <select id="rating-filter" name="rating" onchange="this.form.submit()" style="padding: 8px 12px; border-radius: 4px; border: 1px solid #ddd;">
                    <option value="">All Ratings</option>
                    <option value="4.5" {{#if (eq minRating 4.5)}}selected{{/if}}>4.5+ ⭐</option>
                    <option value="4" {{#if (eq minRating 4)}}selected{{/if}}>4.0+ ⭐</option>
                    <option value="3.5" {{#if (eq minRating 3.5)}}selected{{/if}}>3.5+ ⭐</option>
                    <option value="3" {{#if (eq minRating 3)}}selected{{/if}}>3.0+ ⭐</option>
                </select>
            </div>

            <div>
                <label for="sort-filter" style="font-weight: 600; margin-right: 8px;">Sort by:</label>
                <select id="sort-filter" name="sort" onchange="this.form.submit()" style="padding: 8px 12px; border-radius: 4px; border: 1px solid #ddd;">
                    <option value="newest" {{#if (eq sortBy "newest")}}selected{{/if}}>Newest</option>
                    <option value="rating-high" {{#if (eq sortBy "rating-high")}}selected{{/if}}>Highest Rating</option>
                    <option value="rating-low" {{#if (eq sortBy "rating-low")}}selected{{/if}}>Lowest Rating</option>
                </select>
            </div>

            {{#if minRating}}
            <div>
                <a href="/establishments?q={{ query }}" style="padding: 8px 12px; background: #ff6b6b; color: white; border-radius: 4px; text-decoration: none; font-size: 14px;">Clear Filters</a>
            </div>
            {{/if}}
        </form>
    </div>
</section>

<!-- Establishments List -->
<section class="est-list-section">
    <div class="container">
        <h2>All Establishments Near DLSU</h2>
        <div id="establishmentsList">
            {{#each establishments}}
            <div class="est-list-item">
                <div class="est-list-icon">
                    <img src="{{ imageUrl this.image }}" alt="{{ this.name }}" style="width:60px; height:60px; object-fit:cover; border-radius:8px;">
                </div>
                <div class="est-list-info">
                    <h3><a href="/establishments/{{ this._id }}">{{ this.name }}</a></h3>
                    <div class="est-list-meta">
                        <span class="est-list-rating">{{ stars this.rating }}</span>
                        <span>{{ this.location }}</span>
                        <span>{{ formatAllHours this.hours }}</span>
                        {{#if this.businessStatus}}
                        <span class="status-badge" style="background: {{statusColor this.businessStatus.status}}; color: white;">{{statusEmoji this.businessStatus.status}} {{statusLabel this.businessStatus.status}}</span>
                        {{/if}}
                    </div>
                    <p>{{ this.description }}</p>
                </div>
            </div>
            {{/each}}
        </div>
    </div>
</section>