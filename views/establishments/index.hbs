<!-- Search Section -->
<section class="search-section">
    <div class="container">
        <h1>Find Establishments</h1>
        <form id="searchForm" class="search-form" action="/establishments" method="get">
            <input type="text" id="searchInput" name="q" placeholder="Search for restaurants, cuisines, or locations..." value="{{ query }}">
            <button type="submit">Search</button>
        </form>
        <a href="/establishments"><button type="button" id="resetSearchBtn" class="reset-btn">Show All</button></a>
    </div>
</section>

<!-- Establishments List -->
<section class="est-list-section">
    <div class="container">
        <h2>All Establishments Near DLSU</h2>
        <div id="establishmentsList">
            {{#each establishments}}
            <div class="est-list-item">
                <div class="est-list-icon">
                    <img src="/images/{{ this.image }}" alt="{{ this.name }}" style="width:60px; height:60px; object-fit:cover; border-radius:8px;">
                </div>
                <div class="est-list-info">
                    <h3><a href="/establishments/{{ this._id }}">{{ this.name }}</a></h3>
                    <div class="est-list-meta">
                        <span class="est-list-rating">{{ stars this.rating }}</span>
                        <span>{{ this.location }}</span>
                        <span>{{ this.hours }}</span>
                    </div>
                    <p>{{ this.description }}</p>
                </div>
            </div>
            {{/each}}
        </div>
    </div>
</section>