<section class="hero">
    <img src="/images/taft.jpg" alt="" class="hero-bg"/>
    <div class="hero-overlay"></div>
    <div class="container">
        <h2>Discover restaurants near DLSU</h2>
        <p>Share reviews and find new places to eat around De La Salle University — Manila.</p>
        <form class="hero-search" action="/establishments" method="get">
            <input
                type="text"
                name="q"
                class="hero-search-input"
                placeholder="Search for restaurants, cafes, food courts…"
                autocomplete="off"
            />
            <button type="submit" class="hero-search-btn">Search</button>
        </form>
    </div>
</section>

<!-- Featured Establishments -->
<section class="section">
    <div class="container">
        <div class="section-header">
            <h2>Featured Establishments</h2>
            <a href="/establishments">See all &rarr;</a>
        </div>
        <div class="card-grid">
            {{#each establishments}}
            {{> est-card}}
            {{/each}}
        </div>
    </div>
</section>

<!-- Recent Reviews -->
<section class="section section-alt">
    <div class="container">
        <div class="section-header">
            <h2>Recent Reviews</h2>
        </div>
        <div id="recentReviews" class="reviews-grid">
            {{#each reviews}}
            <div class="review-item">
                <h4><a href="/establishments/{{ this.establishmentId._id }}">{{ this.title }}</a></h4>
                <p>By: <a href="/users/{{ this.userId._id }}">{{ this.userId.name }}</a> on {{ this.establishmentId.name }}</p>
                <p>Rating: {{ stars this.rating }}</p>
            </div>
            {{/each}}
        </div>
    </div>
</section>